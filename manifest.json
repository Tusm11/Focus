{
  "manifest_version": 3,
  "name": "Focus",
  "version": "1.0.0",
  "description": "Transform focus into an RPG experience",
  "permissions": [
    "storage",
    "tabs",
    "webRequest",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/contentScript.js"]
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Focus - Productivity RPG"
  },
  "icons": {
    "16": "src/assets/icon-16.png",
    "48": "src/assets/icon-48.png",
    "128": "src/assets/icon-128.png"
  }
}
